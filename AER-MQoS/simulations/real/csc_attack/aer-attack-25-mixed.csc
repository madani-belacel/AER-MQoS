<simconf>
    <simulation>
      <title>AER-MQoS mixed (N=25, seed=20260601)</title>
      <randomseed>20260601</randomseed>
      <motedelay_us>1000000</motedelay_us>
      <radiomedium>
        org.contikios.cooja.radiomediums.UDGM
        <transmitting_range>35.0</transmitting_range>
        <interference_range>70.0</interference_range>
        <success_ratio_tx>0.85</success_ratio_tx>
        <success_ratio_rx>0.85</success_ratio_rx>
      </radiomedium>
      <events>
        <logoutput>1800000</logoutput>
      </events>
