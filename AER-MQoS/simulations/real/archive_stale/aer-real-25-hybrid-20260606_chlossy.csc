<?xml version="1.0" encoding="UTF-8"?>
<simconf>
  <simulation>
    <title>Hybrid Cooja campaign — 25 motes hybrid seed=20260606 sr_tx=0.85 sr_rx=0.85 | ScriptRunner TIMEOUT=120000 ms sim time</title>
    <randomseed>20260606</randomseed>
    <motedelay_us>1000000</motedelay_us>
    <radiomedium>
      org.contikios.cooja.radiomediums.UDGM
      <transmitting_range>40.0</transmitting_range>
      <interference_range>80.0</interference_range>
      <success_ratio_tx>0.85</success_ratio_tx>
      <success_ratio_rx>0.85</success_ratio_rx>
    </radiomedium>
    <events>
      <logoutput>40000</logoutput>
    </events>
    <motetype>
      org.contikios.cooja.contikimote.ContikiMoteType
      <identifier>mtype_aer_real_hybrid</identifier>
      <description>Multi-protocol RPL campaign node (AER_PROTOCOL_VARIANT in Makefile)</description>
      <source>[CONTIKI_DIR]/examples/AER-MQoS/AER-MQoS/code_source_AER_MQoS/AER-MQoS-node.c</source>
      <commands>$(MAKE) -j$(CPUS) AER-MQoS-node.cooja TARGET=cooja</commands>
      <moteinterface>org.contikios.cooja.interfaces.Position</moteinterface>
      <moteinterface>org.contikios.cooja.interfaces.Battery</moteinterface>
      <moteinterface>org.contikios.cooja.contikimote.interfaces.ContikiVib</moteinterface>
      <moteinterface>org.contikios.cooja.contikimote.interfaces.ContikiMoteID</moteinterface>
